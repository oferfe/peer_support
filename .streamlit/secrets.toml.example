# Copy this file to `.streamlit/secrets.toml` and fill in the real values.
# The real secrets.toml is gitignored and must never be committed.

SUPABASE_URL   = "https://xxx.supabase.co"
SUPABASE_KEY   = "service_role_or_anon_key"

OPENAI_API_KEY = ""
GOOGLE_API_KEY = "..."

OPENAI_MODEL   = "gpt-4o"
GEMMA_MODEL    = "gemma-3-27b-it"

# Deployment mode locks the researcher-facing UI to Hebrew + ChatGPT and hides
# the language selector, model selector, and system status. Leave false/unset
# for local development.
# DEPLOYMENT_MODE = true

# Researcher logins. Add one section per researcher.
# The section name is the username used at login; `name` is the display name
# stored in Supabase as researcher_name.
[researchers.ofer]
name = "Ofer"
password = "replace-with-a-private-password"
